        "# Attention answers: \"for each token, which other tokens should I look at\n",
        "# to understand my meaning in this context?\"\n",
        "#\n",
        "# Three projections are computed from the input X:\n",
        "#   Q = X @ W_Q   (Query  - \"what am I looking for?\")\n",
        "#   K = X @ W_K   (Key    - \"what information do I have?\")\n",
        "#   V = X @ W_V   (Value  - \"what will I actually pass forward?\")\n",
        "#\n",
        "# Attention scores:\n",
        "#   scores = Q @ K.T / sqrt(head_dim)\n",
        "#\n",
        "# The sqrt(head_dim) prevents dot products from becoming very large\n",
        "# (which would push softmax into saturated regions with near-zero gradients).\n",
        "#\n",
        "# Causal mask: position i can only attend to positions 0..i, NOT i+1 onward.\n",
        "# This is critical for language modeling - the model cannot cheat by looking\n",
        "# at future tokens during training.\n",
        "#\n",
        "# Output:\n",
        "#   attention_weights = softmax(scores + mask)\n",
        "#   output = attention_weights @ V\n",
        "print(\"\\n--- SELF-ATTENTION ---\")\n",
        "\n",
        "class SingleHeadAttention(nn.Module):\n",
        "    \"\"\"\n",
        "    One head of causal (masked) self-attention.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    embed_dim : int   - size of the input token vectors\n",
        "    head_dim  : int   - size of Q, K, V projections inside this head\n",
        "    \"\"\"\n",
        "\n",
        "    def __init__(self, embed_dim, head_dim):\n",
        "        super().__init__()\n",
        "\n",
        "        # Three linear projections - no bias, as is standard in transformers\n",
        "        self.W_q = nn.Linear(embed_dim, head_dim, bias=False)  # Query projection\n",
        "        self.W_k = nn.Linear(embed_dim, head_dim, bias=False)  # Key projection\n",
        "        self.W_v = nn.Linear(embed_dim, head_dim, bias=False)  # Value projection\n",
        "\n",
        "        # The causal mask: a lower-triangular matrix of ones.\n",
        "        # Position i can see positions 0..i but NOT i+1..block_size-1.\n",
        "        # register_buffer: saves the mask as part of the model but not a parameter\n",
        "        # (it won't appear in optimizer updates).\n",
        "        self.register_buffer(\n",
        "            \"mask\",\n",
        "            torch.tril(torch.ones(BLOCK_SIZE, BLOCK_SIZE))\n",
        "        )\n",
        "\n",
        "        self.head_dim = head_dim\n",
        "\n",
        "    def forward(self, x):\n",
        "        \"\"\"\n",
        "        x shape: [batch_size, seq_len, embed_dim]\n",
        "        Returns: [batch_size, seq_len, head_dim]\n",
        "        \"\"\"\n",
        "        B, T, C = x.shape   # Batch, Time (seq len), Channels (embed_dim)\n",
        "\n",
        "        Q = self.W_q(x)     # [B, T, head_dim]  - queries\n",
        "        K = self.W_k(x)     # [B, T, head_dim]  - keys\n",
        "        V = self.W_v(x)     # [B, T, head_dim]  - values\n",
        "\n",
        "        # Step 1: compute raw attention scores\n",
        "        # Q @ K.T gives pairwise similarity between every query and every key\n",
        "        # Shape: [B, T, T]\n",
        "        scale = math.sqrt(self.head_dim)\n",
        "        scores = Q @ K.transpose(-2, -1) / scale  # [B, T, T]\n",
        "\n",
        "        # Step 2: apply causal mask\n",
        "        # Fill future positions with -inf so softmax turns them into ~0\n",
        "        mask = self.mask[:T, :T]   # slice to actual seq length\n",
        "        scores = scores.masked_fill(mask == 0, float(\"-inf\"))\n",
        "\n",
        "        # Step 3: softmax converts scores into a probability distribution\n",
        "        # Each row sums to 1; row[i] tells how much token i attends to each past token\n",
        "        weights = F.softmax(scores, dim=-1)  # [B, T, T]\n",
        "\n",
        "        # Step 4: weighted sum of values\n",
        "        # Each output token is a blend of all value vectors, weighted by attention\n",
        "        out = weights @ V   # [B, T, head_dim]\n",
        "\n",
        "        return out, weights  # return weights so we can visualize them\n",
        ""
