        "# The simplest possible tokenizer: each unique character is one token.\n",
        "# This is NOT what GPT uses (GPT uses BPE), but it is the easiest way\n",
        "# to understand the concept before adding complexity.\n",
        "#\n",
        "# Vocabulary = every unique character in the dataset.\n",
        "# Token = integer index of a character.\n",
        "\n",
        "# Step 1: Find all unique characters in the dataset\n",
        "all_chars = sorted(list(set(text)))\n",
        "vocab_size = len(all_chars)\n",
        "\n",
        "print(\"\\n--- CHARACTER-LEVEL TOKENIZER ---\")\n",
        "print(\"Vocabulary size:\", vocab_size, \"unique characters\")\n",
        "print(\"Vocabulary:\", all_chars)\n",
        "\n",
        "# Step 2: Build two lookup tables\n",
        "#   char_to_int : character -> integer  (used during encoding)\n",
        "#   int_to_char : integer  -> character (used during decoding)\n",
        "char_to_int = {ch: i for i, ch in enumerate(all_chars)}\n",
        "int_to_char = {i: ch for i, ch in enumerate(all_chars)}\n",
        "\n",
        "# Step 3: Define encode and decode functions\n",
        "def encode(string):\n",
        "    \"\"\"Convert a string into a list of integers (token IDs).\"\"\"\n",
        "    return [char_to_int[ch] for ch in string]\n",
        "\n",
        "def decode(token_ids):\n",
        "    \"\"\"Convert a list of integers back into a string.\"\"\"\n",
        "    return \"\".join([int_to_char[i] for i in token_ids])\n",
        "\n",
        "# Test the tokenizer\n",
        "sample = \"hello world\"\n",
        "encoded = encode(sample)\n",
        "decoded = decode(encoded)\n",
