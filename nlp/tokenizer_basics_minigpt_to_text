        "# Row i = position i is attending to all past positions.\n",
        "# Bright cell (i, j) = position i attended strongly to position j.\n",
        "print(\"\\n--- ATTENTION VISUALIZATION ---\")\n",
        "\n",
        "# Hook to capture attention weights from the first head of the first block\n",
        "captured_weights = []\n",
        "\n",
        "def capture_hook(module, input, output):\n",
        "    \"\"\"Forward hook: stores the attention weights produced by this head.\"\"\"\n",
        "    with torch.no_grad():\n",
        "        x = input[0]\n",
        "        Q = module.W_q(x)\n",
        "        K = module.W_k(x)\n",
        "        V = module.W_v(x)\n",
        "        scale = math.sqrt(module.head_dim)\n",
        "        scores = Q @ K.transpose(-2, -1) / scale\n",
        "        T = x.shape[1]\n",
        "        mask = module.mask[:T, :T]\n",
        "        scores = scores.masked_fill(mask == 0, float(\"-inf\"))\n",
        "        weights = F.softmax(scores, dim=-1)\n",
        "        captured_weights.append(weights.detach().cpu())\n",
        "\n",
        "# Register hook on the first head of the first block\n",
        "hook = model.blocks[0].attn.heads[0].register_forward_hook(capture_hook)\n",
